{
  "version": 1,
  "bindings": [
    {"id": "nv000001", "app": "neovim", "description": "Enter insert mode", "keys": ["i"], "alternates": ["a", "o"], "tags": ["mode"], "notes": "i=before cursor, a=after cursor, o=new line below"},
    {"id": "nv000002", "app": "neovim", "description": "Enter visual mode", "keys": ["v"], "alternates": ["V", "Ctrl+v"], "tags": ["mode"], "notes": "v=char, V=line, Ctrl+v=block"},
    {"id": "nv000003", "app": "neovim", "description": "Return to normal mode", "keys": ["Esc"], "alternates": ["Ctrl+["], "tags": ["mode"], "notes": ""},
    {"id": "nv000004", "app": "neovim", "description": "Write file", "keys": [":w"], "alternates": [], "tags": ["file"], "notes": ""},
    {"id": "nv000005", "app": "neovim", "description": "Quit", "keys": [":q"], "alternates": [":q!", ":wq", "ZZ"], "tags": ["file"], "notes": "ZZ = write and quit"},
    {"id": "nv000006", "app": "neovim", "description": "Undo", "keys": ["u"], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "nv000007", "app": "neovim", "description": "Redo", "keys": ["Ctrl+r"], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "nv000008", "app": "neovim", "description": "Delete line", "keys": ["dd"], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "nv000009", "app": "neovim", "description": "Yank (copy) line", "keys": ["yy"], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "nv00000a", "app": "neovim", "description": "Paste after cursor", "keys": ["p"], "alternates": ["P"], "tags": ["edit"], "notes": "P = paste before cursor"},
    {"id": "nv00000b", "app": "neovim", "description": "Search forward", "keys": ["/"], "alternates": ["?"], "tags": ["search"], "notes": "? = search backward"},
    {"id": "nv00000c", "app": "neovim", "description": "Next search result", "keys": ["n"], "alternates": ["N"], "tags": ["search"], "notes": "N = previous result"},
    {"id": "nv00000d", "app": "neovim", "description": "Go to definition", "keys": ["gd"], "alternates": [], "tags": ["lsp"], "notes": "Requires LSP"},
    {"id": "nv00000e", "app": "neovim", "description": "Hover documentation", "keys": ["K"], "alternates": [], "tags": ["lsp"], "notes": "Requires LSP"},
    {"id": "nv00000f", "app": "neovim", "description": "Go to file", "keys": ["gf"], "alternates": [], "tags": ["navigation"], "notes": "Open file under cursor"},
    {"id": "nv000010", "app": "neovim", "description": "Jump to matching bracket", "keys": ["%"], "alternates": [], "tags": ["navigation"], "notes": ""},
    {"id": "nv000011", "app": "neovim", "description": "Go to top of file", "keys": ["gg"], "alternates": [], "tags": ["navigation"], "notes": ""},
    {"id": "nv000012", "app": "neovim", "description": "Go to bottom of file", "keys": ["G"], "alternates": [], "tags": ["navigation"], "notes": ""},
    {"id": "nv000013", "app": "neovim", "description": "Go to line number", "keys": [":<number>"], "alternates": ["<number>G"], "tags": ["navigation"], "notes": ""},
    {"id": "nv000014", "app": "neovim", "description": "Split horizontal", "keys": ["Ctrl+w s"], "alternates": [":split"], "tags": ["window"], "notes": ""},
    {"id": "nv000015", "app": "neovim", "description": "Split vertical", "keys": ["Ctrl+w v"], "alternates": [":vsplit"], "tags": ["window"], "notes": ""},
    {"id": "nv000016", "app": "neovim", "description": "Close window", "keys": ["Ctrl+w q"], "alternates": [":close"], "tags": ["window"], "notes": ""},
    {"id": "nv000017", "app": "neovim", "description": "Navigate windows", "keys": ["Ctrl+w h/j/k/l"], "alternates": [], "tags": ["window"], "notes": ""},
    {"id": "nv000018", "app": "neovim", "description": "Next buffer", "keys": [":bnext"], "alternates": [":bn"], "tags": ["buffer"], "notes": ""},
    {"id": "nv000019", "app": "neovim", "description": "Previous buffer", "keys": [":bprev"], "alternates": [":bp"], "tags": ["buffer"], "notes": ""},
    {"id": "nv00001a", "app": "neovim", "description": "Delete buffer", "keys": [":bdelete"], "alternates": [":bd"], "tags": ["buffer"], "notes": ""},
    {"id": "nv00001b", "app": "neovim", "description": "Replace under cursor", "keys": ["r"], "alternates": ["R"], "tags": ["edit"], "notes": "r=single char, R=replace mode"},
    {"id": "nv00001c", "app": "neovim", "description": "Change word", "keys": ["cw"], "alternates": ["ciw"], "tags": ["edit"], "notes": "ciw = change inner word"},
    {"id": "nv00001d", "app": "neovim", "description": "Indent line", "keys": [">>"], "alternates": ["<<"], "tags": ["edit"], "notes": "<< = unindent"},
    {"id": "nv00001e", "app": "neovim", "description": "Repeat last command", "keys": ["."], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "nv00001f", "app": "neovim", "description": "Record macro", "keys": ["q<register>"], "alternates": ["@<register>"], "tags": ["macro"], "notes": "q to stop recording, @ to replay"}
  ]
}
