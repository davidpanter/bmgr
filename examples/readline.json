{
  "version": 1,
  "bindings": [
    {"id": "rl000001", "app": "readline", "description": "Move to beginning of line", "keys": ["Ctrl+a"], "alternates": ["Home"], "tags": ["movement"], "notes": "Works in bash, zsh, and most readline-based programs"},
    {"id": "rl000002", "app": "readline", "description": "Move to end of line", "keys": ["Ctrl+e"], "alternates": ["End"], "tags": ["movement"], "notes": ""},
    {"id": "rl000003", "app": "readline", "description": "Move back one character", "keys": ["Ctrl+b"], "alternates": ["Left"], "tags": ["movement"], "notes": ""},
    {"id": "rl000004", "app": "readline", "description": "Move forward one character", "keys": ["Ctrl+f"], "alternates": ["Right"], "tags": ["movement"], "notes": ""},
    {"id": "rl000005", "app": "readline", "description": "Move back one word", "keys": ["Alt+b"], "alternates": ["Ctrl+Left"], "tags": ["movement"], "notes": ""},
    {"id": "rl000006", "app": "readline", "description": "Move forward one word", "keys": ["Alt+f"], "alternates": ["Ctrl+Right"], "tags": ["movement"], "notes": ""},
    {"id": "rl000007", "app": "readline", "description": "Delete character under cursor", "keys": ["Ctrl+d"], "alternates": ["Delete"], "tags": ["edit"], "notes": "Also sends EOF on empty line"},
    {"id": "rl000008", "app": "readline", "description": "Delete character before cursor", "keys": ["Ctrl+h"], "alternates": ["Backspace"], "tags": ["edit"], "notes": ""},
    {"id": "rl000009", "app": "readline", "description": "Kill to end of line", "keys": ["Ctrl+k"], "alternates": [], "tags": ["kill"], "notes": "Cut text to kill ring"},
    {"id": "rl00000a", "app": "readline", "description": "Kill to beginning of line", "keys": ["Ctrl+u"], "alternates": [], "tags": ["kill"], "notes": ""},
    {"id": "rl00000b", "app": "readline", "description": "Kill word backward", "keys": ["Ctrl+w"], "alternates": ["Alt+Backspace"], "tags": ["kill"], "notes": ""},
    {"id": "rl00000c", "app": "readline", "description": "Kill word forward", "keys": ["Alt+d"], "alternates": [], "tags": ["kill"], "notes": ""},
    {"id": "rl00000d", "app": "readline", "description": "Yank (paste) from kill ring", "keys": ["Ctrl+y"], "alternates": [], "tags": ["kill"], "notes": ""},
    {"id": "rl00000e", "app": "readline", "description": "Cycle through kill ring", "keys": ["Alt+y"], "alternates": [], "tags": ["kill"], "notes": "Use after Ctrl+y to rotate"},
    {"id": "rl00000f", "app": "readline", "description": "Transpose characters", "keys": ["Ctrl+t"], "alternates": [], "tags": ["edit"], "notes": "Swap char before cursor with char at cursor"},
    {"id": "rl000010", "app": "readline", "description": "Transpose words", "keys": ["Alt+t"], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "rl000011", "app": "readline", "description": "Uppercase word", "keys": ["Alt+u"], "alternates": [], "tags": ["edit"], "notes": "From cursor to end of word"},
    {"id": "rl000012", "app": "readline", "description": "Lowercase word", "keys": ["Alt+l"], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "rl000013", "app": "readline", "description": "Capitalize word", "keys": ["Alt+c"], "alternates": [], "tags": ["edit"], "notes": ""},
    {"id": "rl000014", "app": "readline", "description": "Reverse search history", "keys": ["Ctrl+r"], "alternates": [], "tags": ["history"], "notes": "Incremental search backward"},
    {"id": "rl000015", "app": "readline", "description": "Forward search history", "keys": ["Ctrl+s"], "alternates": [], "tags": ["history"], "notes": "May need stty -ixon to enable"},
    {"id": "rl000016", "app": "readline", "description": "Previous history entry", "keys": ["Ctrl+p"], "alternates": ["Up"], "tags": ["history"], "notes": ""},
    {"id": "rl000017", "app": "readline", "description": "Next history entry", "keys": ["Ctrl+n"], "alternates": ["Down"], "tags": ["history"], "notes": ""},
    {"id": "rl000018", "app": "readline", "description": "Insert last argument", "keys": ["Alt+."], "alternates": ["Alt+_"], "tags": ["history"], "notes": "Last arg of previous command, repeat to cycle"},
    {"id": "rl000019", "app": "readline", "description": "Clear screen", "keys": ["Ctrl+l"], "alternates": [], "tags": ["general"], "notes": ""},
    {"id": "rl00001a", "app": "readline", "description": "Cancel current line", "keys": ["Ctrl+c"], "alternates": [], "tags": ["general"], "notes": ""},
    {"id": "rl00001b", "app": "readline", "description": "Undo", "keys": ["Ctrl+_"], "alternates": ["Ctrl+x Ctrl+u"], "tags": ["edit"], "notes": ""},
    {"id": "rl00001c", "app": "readline", "description": "Accept line (execute)", "keys": ["Enter"], "alternates": ["Ctrl+m"], "tags": ["general"], "notes": ""},
    {"id": "rl00001d", "app": "readline", "description": "Quoted insert", "keys": ["Ctrl+v"], "alternates": [], "tags": ["edit"], "notes": "Insert next character literally"},
    {"id": "rl00001e", "app": "readline", "description": "Complete filename/command", "keys": ["Tab"], "alternates": [], "tags": ["completion"], "notes": ""},
    {"id": "rl00001f", "app": "readline", "description": "List completions", "keys": ["Alt+?"], "alternates": ["Tab Tab"], "tags": ["completion"], "notes": ""},
    {"id": "rl000020", "app": "readline", "description": "Suspend process", "keys": ["Ctrl+z"], "alternates": [], "tags": ["general"], "notes": "fg to resume"}
  ]
}
