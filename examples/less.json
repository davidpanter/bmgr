    {"id": "le000016", "app": "less", "description": "Previous file", "keys": [":p"], "alternates": [], "tags": ["file"], "notes": ""},
    {"id": "le000017", "app": "less", "description": "Open file", "keys": [":e"], "alternates": [], "tags": ["file"], "notes": "Prompts for filename"},
